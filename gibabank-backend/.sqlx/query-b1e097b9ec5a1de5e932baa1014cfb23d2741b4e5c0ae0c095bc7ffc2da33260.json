  "query": "\n        SELECT id, account_from_id, account_to_id, amount, transaction_type as \"transaction_type: _\", created_at \n        FROM transactions \n        WHERE account_from_id = $1 OR account_to_id = $1\n        ORDER BY created_at DESC\n        ",
