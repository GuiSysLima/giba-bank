{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id, \n            account_from_id, \n            account_to_id, \n            amount, \n            transaction_type as \"transaction_type: _\", \n            created_at \n        FROM transactions \n        WHERE account_from_id = $1 OR account_to_id = $1\n        ORDER BY created_at DESC\n        ",
